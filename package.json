{
  "name": "gearlabgaming",
  "version": "1.0.0",
  "private": true,
  "description": "GearLabGaming - Gaming Gear Reviews & Guides CMS",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply DB",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:create-migration": "wrangler d1 migrations create DB",
    "type-check": "tsc --noEmit",
    "seed": "tsx scripts/seed-admin.ts"
  },
  "dependencies": {
    "@sonicjs-cms/core": "^2.8.0",
    "hono": "^4.11.7",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^20.19.1",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.44.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.59.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
